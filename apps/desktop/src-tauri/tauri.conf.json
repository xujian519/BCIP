{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "云熙",
  "version": "0.1.0",
  "identifier": "com.xujian519.yunxi",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "云熙智能体",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 650,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "focus": true,
        "transparent": true,
        "backgroundColor": "#FFFFFF",
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "tabbingIdentifier": "YunXi",
        "windowEffects": {
          "effects": ["sidebar", "acrylic"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset: http://asset.localhost tauri: https://tauri.localhost",
        "script-src": "'self' 'unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "connect-src": "ipc: http://ipc.localhost tauri: https://tauri.localhost ws://127.0.0.1:* ws://localhost:* http://127.0.0.1:* http://localhost:* https://api.deepseek.com https://open.bigmodel.cn https://api.moonshot.cn",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "font-src": "'self' data:"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/xujian519/BCIP/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "REPLACE_WITH_GENERATED_PUBKEY",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "externalBin": ["binaries/bcip"],
    "resources": ["target/codex-patent-assets/"],
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["SimpChinese"]
      }
    }
  }
}