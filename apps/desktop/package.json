{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "VITE_DEV_MOCK=1 vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "prepare-sidecar": "bash scripts/prepare-sidecar.sh",
    "icons:generate": "python3 scripts/generate-macos-icons.py",
    "icons:macos": "npm run icons:generate",
    "readme:splash": "python3 scripts/generate-readme-splash.py",
    "tauri:build:bundle": "npm run prepare-sidecar && npm run tauri build",
    "smoke": "bash scripts/smoke-desktop.sh",
    "check:generate-ts": "bash scripts/check-generated-app-server.sh",
    "ci": "npm run lint && npm run build && npm run check:generate-ts && npm run test:e2e",
    "updater:keygen": "npx @tauri-apps/cli signer generate -w ~/.bcip/updater-key",
    "updater:pubkey": "cat ~/.bcip/updater-key.pub",
    "test:e2e:install": "PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "walkthrough:capture": "WALKTHROUGH_CAPTURE=1 PLAYWRIGHT_BROWSERS_PATH=0 playwright test e2e/walkthrough-capture.spec.ts",
    "walkthrough:check": "node scripts/check-walkthrough-screenshots.mjs",
    "walkthrough:report": "node scripts/generate-walkthrough-review.mjs",
    "walkthrough:acceptance": "npm run walkthrough:capture && npm run walkthrough:check && npm run walkthrough:report"
  },
